{
  "manifest_version": 3,
  "name": "Tuma Emprego",
  "version": "0.1.0",
  "description": "Detecta vaga na página, sugere segmento e gera currículo + PDF via Tuma Emprego local.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:3737/*", "http://127.0.0.1:3737/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tuma Emprego",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["config.js", "extract.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
