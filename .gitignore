dados/resultados/*
!dados/resultados/.gitkeep
!dados/resultados/exemplo.yml

dados/busca/*
!dados/busca/.gitkeep
!dados/busca/*.example.yml
dados/pdfs/*
!dados/pdfs/.gitkeep

dados/fotos/*
!dados/fotos/.gitkeep

dados/candidaturas/*
!dados/candidaturas/.gitkeep

dados/portais/solides.yml
