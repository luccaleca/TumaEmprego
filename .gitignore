# Dependencies
node_modules/
.pnp.*

# Next.js (site/)
site/.next/
site/out/

# Env
.env
.env*.local

# Postgres / Prisma
*.db
*.db-journal
site/.env

# SQL: scripts/sql/001-*.sql etc. vão no Git (estrutura do banco).
# Ignorar só dumps/backups com dados reais:
scripts/sql/dumps/
!scripts/sql/dumps/.gitkeep
*.dump
*.backup.sql

# ── Dados pessoais (local) — versionar só *.example.yml / *.example.md ──

dados/cv-base.md
!dados/cv-base.example.md

dados/config/profile.yml
!dados/config/profile.example.yml

dados/config/busca.yml
!dados/config/busca.example.yml

dados/config/formacao.yml
!dados/config/formacao.example.yml

dados/config/tecnologias.yml
!dados/config/tecnologias.example.yml

dados/conteudo/banco.yml
