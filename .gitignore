# Dependencies
node_modules/
.pnp.*

# Next.js (site/)
site/.next/
site/out/

# Env
.env
.env*.local

# Postgres / Prisma
*.db
*.db-journal
site/.env

# SQL: scripts/sql/001-*.sql etc. vão no Git (estrutura do banco).
# Ignorar só dumps/backups com dados reais:
scripts/sql/dumps/
!scripts/sql/dumps/.gitkeep
*.dump
*.backup.sql

# Dados pessoais — não versionar
dados/config/profile.yml
dados/config/busca.yml
dados/pdfs/*
dados/fotos/*
dados/curriculo/principal.pdf
dados/curriculo/segmentacoes/
dados/conteudo/banco.yml
!dados/conteudo/banco.example.yml
!dados/pdfs/.gitkeep
!dados/fotos/.gitkeep

# Playwright
playwright-report/
test-results/
site/test-thumb.png

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.cursor/
*.log

# Relatórios gerados pelo Agent
agente/relatorios/*
!agente/relatorios/.gitkeep
