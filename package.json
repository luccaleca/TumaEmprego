{
  "name": "tuma-emprego",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix site",
    "dev:clean": "powershell -NoProfile -Command \"if (Test-Path site/.next) { Remove-Item -Recurse -Force site/.next }; npm run dev\"",
    "defender:exclude": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Start-Process powershell -Verb RunAs -ArgumentList '-NoProfile -ExecutionPolicy Bypass -File \"\"scripts/defender-exclusions.ps1\"\"'\"",
    "build": "npm run build --prefix site",
    "start": "npm run start --prefix site",
    "lint": "npm run lint --prefix site",
    "install:site": "npm install --prefix site",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-db.ps1",
    "db:generate": "npm run db:generate --prefix site",
    "db:push": "npm run db:push --prefix site",
    "db:migrate": "npm run db:migrate --prefix site",
    "db:seed": "npm run db:seed --prefix site",
    "db:studio": "npm run db:studio --prefix site",
    "db:prepare": "npm run db:generate && npm run db:push && npm run db:seed",
    "adaptar-cv": "node scripts/adaptar-cv-busca.mjs",
    "adaptar-cv-vaga": "node scripts/adaptar-cv-vaga.mjs",
    "pdf": "node scripts/generate-pdf.mjs"
  }
}
